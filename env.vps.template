# =============================================================================
# COPIE ESTE ARQUIVO PARA A VPS: /var/www/recomecar/.env
# Renomeie para .env e troque ***SENHA_DO_BANCO*** e AUTH_SECRET.
# =============================================================================
#
# ANTES, no Postgres da VPS (sudo -u postgres psql), rode:
#
#   CREATE USER recomecar_user WITH PASSWORD 'SUA_SENHA_AQUI';
#   CREATE DATABASE recomecar OWNER recomecar_user;
#   \c recomecar
#   GRANT ALL ON SCHEMA public TO recomecar_user;
#   GRANT ALL PRIVILEGES ON ALL TABLES IN SCHEMA public TO recomecar_user;
#   GRANT ALL PRIVILEGES ON ALL SEQUENCES IN SCHEMA public TO recomecar_user;
#   \q
#
# Use a MESMA senha em ***SENHA_DO_BANCO*** abaixo.
# Se a senha tiver caracteres especiais (@ # : / etc.), use URL-encoding na URL
# ou prefira uma senha só com letras e números.
#
# Gere AUTH_SECRET no servidor: openssl rand -base64 32
# =============================================================================

DATABASE_URL="postgresql://recomecar_user:***SENHA_DO_BANCO***@127.0.0.1:5432/recomecar?schema=public"

AUTH_SECRET="***COLE_AQUI_o_resultado_de_openssl_rand_base64_32***"
AUTH_URL="https://recomecar.site"
NEXT_PUBLIC_APP_URL="https://recomecar.site"

STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""
