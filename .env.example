# Local (SQLite)
DATABASE_URL="file:./dev.db"

# Opcional em VPS: se as fotos gravarem mas não aparecerem, force a pasta (PM2 com cwd errado).
# UPLOADS_ABSOLUTE_PATH="/var/www/recomecar/public/uploads"

# Gere um segredo forte, ex.: `openssl rand -base64 32`
AUTH_SECRET="troque-isso"

# Em produção (ex.: Vercel), defina a URL canônica do site — ajuda cookies/login.
# AUTH_URL="https://recomecar.site"

# URL pública: local para dev; em produção use HTTPS do seu domínio.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# NEXT_PUBLIC_APP_URL="https://recomecar.site"

# Stripe — crie 3 Prices recorrentes (semanal, mensal, anual) e cole os IDs
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID_WEEK=""
STRIPE_PRICE_ID_MONTH=""
STRIPE_PRICE_ID_YEAR=""
# Só ligue após ativar Pix no painel da Stripe (Payment methods) e confirmar suporte no teu caso
STRIPE_ENABLE_PIX="false"
